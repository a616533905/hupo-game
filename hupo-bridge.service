[Unit]
Description=Hupo Game AI Bridge Server
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/hupo-game
ExecStart=/usr/bin/python3 /root/hupo-game/nanobot_bridge.py
ExecStop=/bin/kill -TERM $MAINPID
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
